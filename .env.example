# Issuer wallet — signs updateRoot / registerToken / mint. NEVER commit the real key.
ISSUER_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# Chain config (HashKey Chain testnet is chainId 133)
HASHKEY_TESTNET_RPC=https://testnet.hsk.xyz
NEXT_PUBLIC_CHAIN_ID=133
NEXT_PUBLIC_RPC_URL=https://testnet.hsk.xyz

# Deployed addresses (fill in after `forge script script/Deploy.s.sol`)
NEXT_PUBLIC_COMPLIANCE_GATE_ADDRESS=0x_COMPLIANCE_GATE_ADDRESS
NEXT_PUBLIC_PRIVATE_RWA_ADDRESS=0x_PRIVATE_RWA_ADDRESS
NEXT_PUBLIC_ISSUER_ADDRESS=0x_ISSUER_ADDRESS
# MockKycSBT — demo-only KYC contract deployed alongside ComplianceGate.
# Replace with real HashKey KYC SBT address when using production KYC.
NEXT_PUBLIC_MOCK_KYC_SBT_ADDRESS=0x_MOCK_KYC_SBT_ADDRESS

# Upstash Redis — required for Vercel deployment (group store).
# Leave empty for local dev (falls back to data/group.json).
# Get free credentials at: https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
